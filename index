async function submitTappaForm(){
  const id = document.getElementById('f-id').value;
  const citta = document.getElementById('f-citta').value.trim();
  if (!citta){ toast('Inserisci almeno il nome della città'); return; }
  const payload = {
    citta,
    dataArrivo: document.getElementById('f-arrivo').value,
    dataPartenza: document.getElementById('f-partenza').value,
    alloggio: {
      nome: document.getElementById('f-alloggioNome').value.trim(),
      indirizzo: document.getElementById('f-alloggioIndirizzo').value.trim(),
      checkIn: document.getElementById('f-checkin').value.trim(),
      checkOut: document.getElementById('f-checkout').value.trim(),
    },
    cittaInfo: {
      tagline: document.getElementById('f-cittaTagline').value.trim(),
      fatti: document.getElementById('f-cittaFatti').value.trim()
    },
    note: document.getElementById('f-note').value.trim()
  };
  if (id){
    const t = state.tappe.find(x=>x.id===id);
    Object.assign(t, payload);
  } else {
    state.tappe.push({ id:genId(), ...payload, giorni:[], segmenti:[], documenti:[] });
  }
  closeModal();
  await saveState();
  render();
}
async function deleteTappa(id){
  if (!confirm('Eliminare questa tappa e tutti i trasporti e documenti collegati? Non si può annullare.')) return;
  const t = state.tappe.find(x=>x.id===id);
  if (t){ for (const d of (t.documenti||[])) await deleteDocBlob(d.id); }
  state.tappe = state.tappe.filter(x=>x.id!==id);
  await saveState();
  render();
}

