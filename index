let pendingDoc = null;
async function handleDocFileChosen(file){
  if (!file) return;
  const preview = document.getElementById('fd-preview');
  preview.textContent = 'Elaborazione in corso…';
  document.getElementById('fd-save-btn').disabled = true;
  try{
    pendingDoc = await processFileForUpload(file);
    preview.innerHTML = pendingDoc.isPdf
      ? `PDF pronto: ${esc(pendingDoc.nomeFile)}`
      : `<img src="${pendingDoc.thumb}" style="width:60px;height:60px;object-fit:cover;border-radius:8px;vertical-align:middle;margin-right:8px;">Immagine pronta`;
    if (!document.getElementById('fd-nome').value) document.getElementById('fd-nome').value = file.name.replace(/\.[^.]+$/,'');
    document.getElementById('fd-save-btn').disabled = false;
  }catch(err){
    pendingDoc = null;
    preview.textContent = 'File troppo grande o non valido. Provane un altro (max ~3.5MB).';
  }
}
async function submitDocForm(){
  if (!pendingDoc){ toast('Scegli prima un file'); return; }
  const tappaId = document.getElementById('fd-tappaId').value || null;
  const nome = document.getElementById('fd-nome').value.trim() || 'Documento';
  const id = genId();
  const ok = await saveDocBlob(id, pendingDoc.full);
  if (!ok){ toast('Errore nel salvataggio del documento'); return; }
  const meta = { id, nome, mimeType: pendingDoc.mimeType, thumb: pendingDoc.thumb, isPdf: pendingDoc.isPdf };
  if (tappaId){
    state.tappe.find(x=>x.id===tappaId).documenti.push(meta);
  } else {
    state.documentiGenerali.push(meta);
  }
  pendingDoc = null;
  closeModal();
  await saveState();
  render();
}
async function deleteDocumento(id, tappaId){
  if (!confirm('Eliminare questo documento?')) return;
  await deleteDocBlob(id);
  if (tappaId){
    const t = state.tappe.find(x=>x.id===tappaId);
    t.documenti = t.documenti.filter(d=>d.id!==id);
  } else {
    state.documentiGenerali = state.documentiGenerali.filter(d=>d.id!==id);
  }
  await saveState();
  render();
}

/* =========================================================================
   LIGHTBOX
   ========================================================================= */
function findDocMeta(id){
  for (const d of state.documentiGenerali) if (d.id===id) return d;
  for (const t of state.tappe) for (const d of (t.documenti||[])) if (d.id===id) return d;
  return null;
}
async function viewDocument(id){
  const meta = findDocMeta(id);
  if (!meta) return;
  const lb = document.getElementById('lightbox');
  const content = document.getElementById('lightboxContent');
  content.innerHTML = `<div class="lightbox-loading">Carico ${meta.isPdf?'il PDF':'la foto'}…</div>`;
  lb.classList.add('show');
  const full = await loadDocBlob(id);
  if (!full){ content.innerHTML = `<div class="lightbox-loading">Documento non trovato o non ancora sincronizzato.</div>`; return; }
  if (meta.isPdf){
    const a = document.createElement('a');
    a.href = full; a.download = meta.nome + '.pdf'; document.body.appendChild(a); a.click(); a.remove();
    content.innerHTML = `<div class="lightbox-loading">Download avviato: ${esc(meta.nome)}</div>`;
  } else {
    content.innerHTML = `<img src="${full}" alt="${esc(meta.nome)}"><div class="lightbox-caption">${esc(meta.nome)}</div>`;
  }
}
function closeLightbox(){
  document.getElementById('lightbox').classList.remove('show');
  document.getElementById('lightboxContent').innerHTML = '';
}

/* =========================================================================
   BACKUP — esporta / importa
   ========================================================================= */
async function aggiornaContenuti(){
  if (!confirm('Aggiornare testi e orari con la versione più recente? I documenti che hai caricato (foto/PDF) non verranno toccati, ma le note e gli orari precaricati verranno sovrascritti. Continuare?')) return;
  const fresh = buildSeedState();
  // preserve any real uploads (documenti) per tappa esistente, e i documenti generali
  fresh.documentiGenerali = state.documentiGenerali || [];
  fresh.tappe.forEach(t => {
    const old = (state.tappe || []).find(x => x.id === t.id);
    if (old && old.documenti && old.documenti.length) t.documenti = old.documenti;
  });
  // mantieni eventuali tappe aggiunte a mano dall'utente che non esistono nel template
  const freshIds = new Set(fresh.tappe.map(t => t.id));
  (state.tappe || []).forEach(t => {
    if (!freshIds.has(t.id)) fresh.tappe.push(t);
  });
  state = fresh;
  await saveState();
  render();
  toast('Contenuti aggiornati alla versione più recente');
}

async function exportBackup(){
  toast('Preparazione backup…');
  const ids = [];
  state.documentiGenerali.forEach(d=>ids.push(d.id));
  state.tappe.forEach(t=>(t.documenti||[]).forEach(d=>ids.push(d.id)));
  const docs = {};
  for (const id of ids){ docs[id] = await loadDocBlob(id); }
  const payload = { state, docs, exportedAt: new Date().toISOString() };
  const blob = new Blob([JSON.stringify(payload)], {type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  const d = new Date();
  a.href = url;
  a.download = `backup-giappone-${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}.json`;
  document.body.appendChild(a); a.click(); a.remove();
  URL.revokeObjectURL(url);
  toast('Backup scaricato');
}
function handleImportInput(ev){
  const file = ev.target.files[0];
  if (file) importBackup(file);
  ev.target.value = '';
}
async function importBackup(file){
  if (!confirm('Importare questo backup sovrascriverà i dati attuali su questo dispositivo. Continuare?')) return;
  try{
    const text = await file.text();
    const payload = JSON.parse(text);
    state = payload.state;
    for (const [id, val] of Object.entries(payload.docs||{})){
      if (val) await saveDocBlob(id, val);
    }
    await saveState();
    render();
    toast('Backup importato');
  }catch(e){
    toast('File di backup non valido');
  }
}

/* =========================================================================
   AVVIO
   ========================================================================= */
(async function init(){
  if (!window.indexedDB){
    storageOk = false;
  } else {
    try { await idbOpen(); } catch(e){ storageOk = false; }
  }
  await loadState();
  document.getElementById('loading').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  render();
  if (isFirstRun && storageOk){ await saveState(); }
  if (!storageOk) toast('Salvataggio automatico non disponibile in questo browser');
})();
</script>
