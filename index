    wrap.innerHTML = `<div class="empty"><b>Nessuna tappa ancora</b>Aggiungi la prima città del tuo itinerario per iniziare.</div>`;
    return;
  }

  wrap.innerHTML = tappe.map((t,i)=>renderTappaCard(t,i+1)).join('');
}

function renderTappaCard(t, num){
  const giorni = [...(t.giorni||[])].sort((a,b)=>(a.data||'').localeCompare(b.data||''));
  const segmenti = [...(t.segmenti||[])].sort((a,b)=>(a.partenza||'').localeCompare(b.partenza||''));
  const documenti = t.documenti || [];
  const range = t.dataArrivo && t.dataPartenza ? `${fmtDataBreve(t.dataArrivo)} – ${fmtData(t.dataPartenza)}`
              : t.dataArrivo ? `Dal ${fmtData(t.dataArrivo)}` : 'Date da definire';

  function renderSegmentoRow(s){
    const {ora} = splitDateTime(s.partenza);
    const {ora:oraArr} = splitDateTime(s.arrivo);
    const metaParts = [];
    if (s.numero) metaParts.push(esc(s.numero));
    if (s.posto) metaParts.push('Posto '+esc(s.posto));
    if (s.note) metaParts.push(esc(s.note));
    const mapsUrl = mapsLinkFor(s);
    return `
    <div class="segmento">
      <div class="segmento-top">
        <span class="badge" data-tipo="${s.tipo}">${esc(tipoLabel(s.tipo))}</span>
        <div class="segmento-top-right">
          <span class="segmento-time">${ora||'--:--'}${oraArr?` → ${oraArr}`:''}</span>
          <button class="icon-btn" style="width:28px;height:28px;border-radius:8px;" onclick="openSegmentoForm('${t.id}','${s.id}')" aria-label="Modifica">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
          </button>
        </div>
      </div>
      <div class="segmento-route">${esc(s.origine||'')}${(s.origine&&s.destinazione)?'<span class="arrow"> → </span>':''}${esc(s.destinazione||'')}</div>
      ${metaParts.length?`<div class="segmento-meta">${metaParts.join(' · ')}</div>`:''}
      ${mapsUrl?`<a class="segmento-maps" href="${mapsUrl}" target="_blank" rel="noopener">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        Apri il percorso in Maps
      </a>`:''}
    </div>`;
  }

  const usedSegIds = new Set();
  let giorniHtml = giorni.length ? giorni.map(g=>{
    const matchSeg = segmenti.filter(s=>splitDateTime(s.partenza).data === g.data);
    matchSeg.forEach(s=>usedSegIds.add(s.id));
    const weekday = fmtWeekday(g.data);
    return `
    <details class="giorno">
      <summary>
        <div class="giorno-head">
          <div class="giorno-heading">
            <div class="giorno-data">${fmtData(g.data)}${weekday?' · '+weekday:''}</div>
            ${g.titolo?`<div class="giorno-titolo">${esc(g.titolo)}</div>`:''}
          </div>
          <div class="giorno-actions">
            <button class="icon-btn" style="width:28px;height:28px;border-radius:8px;" onclick="event.stopPropagation(); event.preventDefault(); openGiornoForm('${t.id}','${g.id}')" aria-label="Modifica giorno">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
            </button>
            <span class="giorno-chev"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></span>
          </div>
        </div>
      </summary>
      <div class="giorno-body">
        ${g.note?`<div class="giorno-note">${esc(g.note)}</div>`:''}
        ${matchSeg.length?`<div class="giorno-segmenti">${matchSeg.map(renderSegmentoRow).join('')}</div>`:''}
      </div>
    </details>`;
  }).join('') : `<div class="empty" style="padding:14px;">Nessun giorno ancora. Aggiungi il programma giorno per giorno di questa tappa.</div>`;

  const orfani = segmenti.filter(s=>!usedSegIds.has(s.id));
  const orfaniHtml = orfani.length
    ? `<div class="tappa-block"><div class="blk-head"><h4>Altri trasporti</h4><span class="sub" style="font-family:var(--f-mono); font-size:11px; color:var(--mist);">non legati a un giorno specifico</span></div>${orfani.map(renderSegmentoRow).join('')}</div>`
    : '';

  let docHtml = `<div class="doc-grid">`;
  documenti.forEach(d=> docHtml += renderDocChip(d, t.id));
  docHtml += `
    <button class="doc-add" onclick="openDocForm('${t.id}')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
      Aggiungi
    </button>
  </div>`;

  const hotelUrl = (t.alloggio && t.alloggio.nome) ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(t.alloggio.nome+', '+(t.citta||''))}` : null;
  const ci = t.cittaInfo || {};
  const fattiList = (ci.fatti||'').split('\n').map(s=>s.trim()).filter(Boolean);
  const cittaInfoHtml = (ci.tagline || fattiList.length) ? `
    <div class="citta-info">
      ${ci.tagline?`<p class="tagline">${esc(ci.tagline)}</p>`:''}
      ${fattiList.length?`<ul>${fattiList.map(f=>`<li>${esc(f)}</li>`).join('')}</ul>`:''}
    </div>` : '';

  const alloggioHtml = (t.alloggio && t.alloggio.nome) ? `
    <div class="alloggio-card">
      <div class="nome">${esc(t.alloggio.nome)}</div>
      ${t.alloggio.indirizzo?`<div class="riga">${esc(t.alloggio.indirizzo)}</div>`:''}
      ${(t.alloggio.checkIn||t.alloggio.checkOut)?`<div class="riga"><b>Check-in/out:</b> ${esc(t.alloggio.checkIn||'?')} → ${esc(t.alloggio.checkOut||'?')}</div>`:''}
      ${t.alloggio.note?`<div class="riga">${esc(t.alloggio.note)}</div>`:''}
      ${hotelUrl?`<a class="hotel-maps-btn" href="${hotelUrl}" target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        Apri hotel in Maps
      </a>`:''}
    </div>` : `<div class="empty" style="padding:14px;">Nessun alloggio registrato.</div>`;

  const noteTappaHtml = (t.note && t.note.trim())
    ? `<div class="tappa-block"><div class="blk-head"><h4>Appunti</h4></div><div class="tappa-note-block">${esc(t.note)}</div></div>`
    : '';

  return `
    <details class="tappa">
      <summary>
        <span class="tappa-num">${String(num).padStart(2,'0')}</span>
        <div class="tappa-info">
          <h3>${esc(t.citta || 'Tappa senza nome')}</h3>
          <div class="range">${range}</div>
        </div>
        <span class="tappa-chev"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></span>
      </summary>
      <div class="tappa-body">
        ${cittaInfoHtml?`<div class="tappa-block"><div class="blk-head"><h4>Da sapere</h4></div>${cittaInfoHtml}</div>`:''}
        <div class="tappa-block">
          <div class="blk-head"><h4>Alloggio</h4></div>
          ${alloggioHtml}
        </div>
        <div class="tappa-block">
          <div class="blk-head"><h4>Giorno per giorno</h4></div>
          ${giorniHtml}
        </div>
        ${orfaniHtml}
        ${noteTappaHtml}
        <div class="tappa-block">
          <div class="blk-head"><h4>Biglietti e documenti</h4></div>
          ${docHtml}
        </div>
        <div class="tappa-footer-actions">
          <button class="btn btn-ghost btn-sm" onclick="openGiornoForm('${t.id}')">+ Giorno</button>
          <button class="btn btn-ghost btn-sm" onclick="openSegmentoForm('${t.id}')">+ Trasporto</button>
          <button class="btn btn-ghost btn-sm" onclick="openTappaForm('${t.id}')">Modifica tappa</button>
          <button class="btn-danger-text" onclick="deleteTappa('${t.id}')">Elimina tappa</button>
        </div>
      </div>
    </details>`;
}

