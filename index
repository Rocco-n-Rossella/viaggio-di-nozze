function genId(){
  if (window.crypto && crypto.randomUUID) return crypto.randomUUID();
  return 'id-'+Date.now()+'-'+Math.random().toString(36).slice(2,9);
}
function esc(s){
  return String(s==null?'':s).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function fmtData(yyyyMmDd){
  if (!yyyyMmDd) return '';
  const [y,m,d] = yyyyMmDd.split('-');
  return `${parseInt(d,10)} ${MONTHS_IT[parseInt(m,10)-1]} ${y}`;
}
function fmtDataBreve(yyyyMmDd){
  if (!yyyyMmDd) return '';
  const [y,m,d] = yyyyMmDd.split('-');
  return `${parseInt(d,10)} ${MONTHS_IT[parseInt(m,10)-1]}`;
}
const WEEKDAYS_IT = ['domenica','lunedì','martedì','mercoledì','giovedì','venerdì','sabato'];
function fmtWeekday(yyyyMmDd){
  if (!yyyyMmDd) return '';
  const d = new Date(yyyyMmDd+'T00:00:00');
  if (isNaN(d.getTime())) return '';
  return WEEKDAYS_IT[d.getDay()];
}
function splitDateTime(dt){
  if (!dt) return {data:'', ora:''};
  const [data, ora] = dt.split('T');
  return {data, ora: ora||''};
}
function toast(msg){
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(el._t);
  el._t = setTimeout(()=>el.classList.remove('show'), 2600);
}
function tipoLabel(v){ return (TIPI_TRASPORTO.find(t=>t.v===v)||{l:v}).l; }

function mapsLinkFor(s){
  if (s.tipo === 'aereo') return null; // una rotta aerea non ha senso su una mappa stradale/transit
  const o = (s.origine||'').trim();
  const d = (s.destinazione||'').trim();
  const mode = s.tipo === 'piedi' ? 'walking' : 'transit';
  if (o && d){
    return `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(o)}&destination=${encodeURIComponent(d)}&travelmode=${mode}`;
  }
  if (d){
    return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(d)}`;
  }
  return null;
}

/* =========================================================================
   GESTIONE FILE (immagini / pdf) — ridimensionamento lato client
   ========================================================================= */
function readAsDataURL(file){
  return new Promise((resolve,reject)=>{
    const r = new FileReader();
    r.onload = e=>resolve(e.target.result);
    r.onerror = reject;
    r.readAsDataURL(file);
  });
}
function resizeImageFile(file, maxDim, quality){
  return new Promise((resolve,reject)=>{
    const r = new FileReader();
    r.onload = e=>{
      const img = new Image();
      img.onload = ()=>{
        let {width,height} = img;
        if (width>maxDim || height>maxDim){
          if (width>height){ height = Math.round(height*maxDim/width); width = maxDim; }
          else { width = Math.round(width*maxDim/height); height = maxDim; }
        }
        const canvas = document.createElement('canvas');
        canvas.width = width; canvas.height = height;
        canvas.getContext('2d').drawImage(img,0,0,width,height);
        resolve(canvas.toDataURL('image/jpeg', quality));
      };
      img.onerror = reject;
      img.src = e.target.result;
    };
    r.onerror = reject;
    r.readAsDataURL(file);
  });
}

async function processFileForUpload(file){
  const isPdf = file.type === 'application/pdf';
  let full, thumb = null;
  if (isPdf){
    full = await readAsDataURL(file);
  } else {
    full = await resizeImageFile(file, 1800, 0.82);
    if (full.length > 4600000){
      full = await resizeImageFile(file, 1300, 0.68);
    }
    thumb = await resizeImageFile(file, 220, 0.55);
  }
  if (full.length > 4800000){
    throw new Error('toolarge');
  }
  return { full, thumb, isPdf, mimeType:file.type, nomeFile:file.name };
}

/* =========================================================================
   RICERCA PROSSIMO EVENTO (per il tabellone)
   ========================================================================= */
function getNextEvent(){
  const events = [];
  state.tappe.forEach(t=>{
    if (t.dataArrivo) events.push({when:new Date(t.dataArrivo+'T00:00:00'), kind:'arrivo', tappa:t});
    (t.segmenti||[]).forEach(s=>{
      if (s.partenza) events.push({when:new Date(s.partenza), kind:'segmento', tappa:t, segmento:s});
    });
  });
  events.sort((a,b)=>a.when-b.when);
  const now = new Date();
  const upcoming = events.filter(e=>e.when >= now);
  if (upcoming.length){
    const idx = events.indexOf(upcoming[0]);
    return {evt:upcoming[0], isPast:false, after:events[idx+1]||null};
  }
  if (events.length) return {evt:events[events.length-1], isPast:true, after:null};
  return null;
}

