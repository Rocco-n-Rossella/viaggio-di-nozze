function renderHeader(){
  document.getElementById('tripTitle').textContent = state.trip.titolo || 'Giappone';
  const {dataInizio, dataFine} = state.trip;
  let txt = '';
  if (dataInizio && dataFine) txt = `${fmtDataBreve(dataInizio)} — ${fmtData(dataFine)}`;
  else if (dataInizio) txt = `Dal ${fmtData(dataInizio)}`;
  document.getElementById('tripDates').textContent = txt;
}

function renderHero(){
  const hero = document.getElementById('hero');
  const next = getNextEvent();
  hero.classList.toggle('past', !!(next && next.isPast));

  if (!next){
    hero.innerHTML = `
      <div class="hero-empty">
        <div class="hero-label"><span class="dot"></span>Tabellone partenze</div>
        <p>Qui apparirà il conto alla rovescia per la tua prossima tappa o trasporto, appena ne aggiungi uno.</p>
      </div>`;
    return;
  }

  const {evt, isPast, after} = next;
  const now = new Date();
  const diffMs = evt.when - now;
  const diffDays = Math.round(diffMs/86400000);
  let countdownTxt, countdownCls = '';
  if (isPast){
    countdownTxt = 'CONCLUSO';
  } else if (diffDays <= 0){
    countdownTxt = 'OGGI'; countdownCls = 'today';
  } else if (diffDays === 1){
    countdownTxt = 'DOMANI';
  } else {
    countdownTxt = `TRA ${diffDays} GIORNI`;
  }

  let routeHtml, timeHtml, badgeHtml = '';
  if (evt.kind === 'segmento'){
    const s = evt.segmento;
    routeHtml = `${esc(s.origine||'?')} <span style="opacity:.55">→</span> ${esc(s.destinazione||'?')}`;
    const {ora} = splitDateTime(s.partenza);
    timeHtml = (ora||'--:--').split('').map(c=>`<span class="d">${c}</span>`).join('');
    badgeHtml = `<span class="badge" data-tipo="${s.tipo}">${esc(tipoLabel(s.tipo))}</span>`;
  } else {
    routeHtml = `Arrivo a ${esc(evt.tappa.citta||'?')}`;
    timeHtml = '';
  }

  const dataStr = evt.kind==='segmento' ? fmtData(splitDateTime(evt.segmento.partenza).data) : fmtData(evt.tappa.dataArrivo);

  // se subito dopo c'è un altro trasporto lo stesso giorno (es. uno scalo), accenniamolo
  let nextLegHtml = '';
  if (!isPast && after && after.kind==='segmento'){
    const sameDay = splitDateTime(after.segmento.partenza||'').data === splitDateTime(evt.kind==='segmento'?evt.segmento.partenza:'').data;
    if (sameDay){
      const {ora:oraAfter} = splitDateTime(after.segmento.partenza);
      nextLegHtml = `<div class="hero-nextleg">Poi: ${esc(after.segmento.origine||'')} → ${esc(after.segmento.destinazione||'')}${oraAfter?' · '+oraAfter:''}</div>`;
    }
  }

  hero.innerHTML = `
    <div class="hero-label"><span class="dot"></span>${isPast ? 'Ultimo evento del viaggio' : 'Prossimo evento'}</div>
    <div class="hero-route">${routeHtml}</div>
    <div class="hero-row">
      <div>
        ${timeHtml ? `<div class="hero-time">${timeHtml}</div>` : ''}
        <div class="hero-date">${dataStr}</div>
      </div>
      <div class="hero-countdown ${countdownCls}">${countdownTxt}</div>
    </div>
    <div class="hero-meta">
      ${badgeHtml}
      ${evt.kind==='segmento' && evt.segmento.numero ? `<span><b>${esc(evt.segmento.numero)}</b></span>` : ''}
      ${evt.kind==='segmento' && evt.segmento.posto ? `<span>Posto <b>${esc(evt.segmento.posto)}</b></span>` : ''}
    </div>
    ${nextLegHtml}`;
}

