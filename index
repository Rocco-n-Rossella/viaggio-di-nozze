<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
<title>Diario di viaggio — Giappone</title>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Giappone">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#22395B">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='48' fill='%23C2452A'/%3E%3Ctext x='50' y='66' font-size='48' text-anchor='middle' fill='white' font-family='sans-serif'%3E旅%3C/text%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@500;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ===================================================================
   TOKENS — colori tradizionali giapponesi (nihon no iro) + tipografia
   =================================================================== */
:root{
  --sumi:#1C1B1A;        /* 墨 ink — testo principale */
  --washi:#F6F1E7;       /* 生成り carta — sfondo */
  --washi-deep:#EBE3D3;  /* carta più profonda — superfici carte */
  --washi-card:#FCFAF4;  /* carta chiara — schede sopra washi-deep */
  --kon:#22395B;         /* 紺 indigo — chrome primario, shinkansen */
  --kon-soft:#3A5680;
  --shu:#C2452A;         /* 朱 vermiglio — cta, alloggio, evidenza */
  --shu-soft:#E1714F;
  --matcha:#5C7A52;      /* 抹茶 — treno locale */
  --sora:#4A7FA0;        /* 空色 cielo — volo */
  --odo:#B07A2C;         /* 黄土 ocra — bus */
  --seiji:#3E7B73;       /* 青磁 celadon — traghetto */
  --tsuchi:#7C6A4E;      /* 土 terra — a piedi */
  --kin:#A8843C;         /* 金 oro — accenti decorativi */
  --kin-soft:#C9A857;
  --mist:#8C8579;        /* testo secondario / didascalie */
  --line:rgba(28,27,26,0.13);
  --line-strong:rgba(28,27,26,0.22);
  --shadow:0 1px 2px rgba(28,27,26,0.06), 0 6px 16px rgba(28,27,26,0.07);

  --f-display:'Zen Kaku Gothic New', 'Hiragino Sans', sans-serif;
  --f-body:'IBM Plex Sans', sans-serif;
  --f-mono:'IBM Plex Mono', monospace;
}

*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  background:var(--washi);
  color:var(--sumi);
  font-family:var(--f-body);
  font-size:16px;
  line-height:1.5;
  -webkit-tap-highlight-color:transparent;
  background-image:
    radial-gradient(circle at 50% 100%, transparent 0, transparent 12px, rgba(194,69,42,0.09) 12px, rgba(194,69,42,0.09) 13px, transparent 13px),
    radial-gradient(circle at 50% 100%, transparent 0, transparent 12px, rgba(194,69,42,0.09) 12px, rgba(194,69,42,0.09) 13px, transparent 13px);
  background-size: 26px 26px;
  background-position: 0 0, 13px 0;
}
button, input, textarea, select{font-family:inherit; font-size:16px;}
button{touch-action:manipulation; cursor:pointer;}
h1,h2,h3,h4{font-family:var(--f-display); margin:0; font-weight:700;}
:focus-visible{outline:2.5px solid var(--shu); outline-offset:2px; border-radius:4px;}
@media (prefers-reduced-motion: reduce){ *{animation-duration:0.001ms !important; transition-duration:0.001ms !important;} }

.wrap{max-width:640px; margin:0 auto; padding:0 16px 96px;}

/* ===================== LOADING ===================== */
#loading{
  min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:10px; color:var(--mist); font-family:var(--f-mono); letter-spacing:.04em;
}
.spinner{width:28px; height:28px; border:3px solid var(--line); border-top-color:var(--kon); border-radius:50%; animation:spin 0.8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

/* ===================== HEADER ===================== */
.appbar{padding:22px 0 14px; display:flex; justify-content:space-between; align-items:flex-start; gap:10px;}
.appbar .eyebrow{font-family:var(--f-mono); font-size:11px; letter-spacing:.12em; color:var(--mist); text-transform:uppercase;}
.appbar h1{font-size:26px; color:var(--kon); margin-top:2px; line-height:1.15;}
.hanko-seal{
  width:38px; height:38px; border-radius:50%; background:var(--shu); color:var(--washi); flex:none;
  display:flex; align-items:center; justify-content:center; font-family:var(--f-display); font-size:17px; font-weight:700;
  border:1.5px solid #8C341E; box-shadow:inset 0 0 0 1.5px rgba(255,255,255,0.5); margin-top:3px;
}
.appbar .dates{font-family:var(--f-mono); font-size:13px; color:var(--mist); margin-top:4px;}
.icon-btn{
  width:38px; height:38px; border-radius:10px; border:1.5px solid var(--line-strong); background:var(--washi-card);
  display:flex; align-items:center; justify-content:center; flex:none; color:var(--sumi);
}
.icon-btn:active{background:var(--washi-deep);}

/* ===================== SECTION HEADERS ===================== */
.section-head{display:flex; align-items:baseline; justify-content:space-between; margin:30px 0 12px;}
.section-head h2{font-size:15px; letter-spacing:.06em; text-transform:uppercase; color:var(--sumi); display:flex; align-items:center; gap:8px;}
.section-head h2::before{content:''; width:7px; height:7px; background:var(--shu); transform:rotate(45deg); flex:none; display:inline-block;}
.section-head .sub{font-family:var(--f-mono); font-size:11.5px; color:var(--mist);}

/* ===================== BUTTONS ===================== */
.btn{
  appearance:none; border:none; border-radius:11px; padding:12px 18px; font-weight:600; font-size:14.5px;
  display:inline-flex; align-items:center; gap:8px; line-height:1; min-height:46px;
}
.btn-primary{background:var(--shu); color:var(--washi); box-shadow:var(--shadow);}
.btn-primary:active{background:#A6391F;}
.btn-ghost{background:transparent; color:var(--kon); border:1.5px dashed var(--line-strong);}
.btn-ghost:active{background:var(--washi-deep);}
.btn-block{width:100%; justify-content:center;}
.btn-sm{padding:8px 13px; min-height:36px; font-size:13px; border-radius:9px;}
.btn-text{background:none; border:none; color:var(--mist); font-size:13px; text-decoration:underline; padding:4px 0;}
.btn-danger-text{background:none; border:none; color:var(--shu); font-size:13px; padding:4px 0;}

/* ===================== HERO — TABELLONE PARTENZE ===================== */
.hero{
  background-color: var(--kon);
  background-image:
    linear-gradient(to right, var(--kin-soft) 2px, transparent 2px), linear-gradient(to bottom, var(--kin-soft) 2px, transparent 2px),
    linear-gradient(to left, var(--kin-soft) 2px, transparent 2px), linear-gradient(to bottom, var(--kin-soft) 2px, transparent 2px),
    linear-gradient(to right, var(--kin-soft) 2px, transparent 2px), linear-gradient(to top, var(--kin-soft) 2px, transparent 2px),
    linear-gradient(to left, var(--kin-soft) 2px, transparent 2px), linear-gradient(to top, var(--kin-soft) 2px, transparent 2px),
    linear-gradient(165deg, var(--kon) 0%, #1A2D49 100%);
  background-repeat: no-repeat;
  background-size: 16px 2px, 2px 16px, 16px 2px, 2px 16px, 16px 2px, 2px 16px, 16px 2px, 2px 16px, 100% 100%;
  background-position:
    top 10px left 10px, top 10px left 10px,
    top 10px right 10px, top 10px right 10px,
    bottom 10px left 10px, bottom 10px left 10px,
    bottom 10px right 10px, bottom 10px right 10px,
    0 0;
  border-radius:18px; padding:22px 20px 20px; color:var(--washi);
  box-shadow:0 10px 30px rgba(20,30,50,0.28);
  position:relative; overflow:hidden;
}
.hero::after{
  content:''; position:absolute; inset:0; pointer-events:none;
  background:repeating-linear-gradient(0deg, rgba(255,255,255,0.025) 0px, rgba(255,255,255,0.025) 1px, transparent 1px, transparent 3px);
}
.hero-label{font-family:var(--f-mono); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:#9FB3CE; display:flex; align-items:center; gap:8px;}
.hero-label .dot{width:6px; height:6px; border-radius:50%; background:var(--shu-soft); box-shadow:0 0 0 0 rgba(225,113,79,.6); animation:pulse 2s infinite;}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(225,113,79,.55);}70%{box-shadow:0 0 0 7px rgba(225,113,79,0);}100%{box-shadow:0 0 0 0 rgba(225,113,79,0);}}
.hero-route{font-family:var(--f-display); font-size:21px; font-weight:700; margin-top:10px; letter-spacing:.01em;}
.hero-row{display:flex; align-items:flex-end; justify-content:space-between; margin-top:14px; gap:14px;}
.hero-time{font-family:var(--f-mono); font-size:44px; font-weight:700; letter-spacing:.01em; display:flex;}
.hero-time .d{display:inline-block; animation:flap .55s cubic-bezier(.2,.9,.25,1) backwards;}
.hero-time .d:nth-child(1){animation-delay:.02s;} .hero-time .d:nth-child(2){animation-delay:.08s;}
.hero-time .d:nth-child(3){animation-delay:.14s;} .hero-time .d:nth-child(4){animation-delay:.20s;}
.hero-time .d:nth-child(5){animation-delay:.26s;}
@keyframes flap{0%{opacity:0; transform:translateY(10px) rotateX(45deg); filter:blur(1px);} 100%{opacity:1; transform:translateY(0) rotateX(0); filter:blur(0);}}
.hero-date{font-family:var(--f-mono); font-size:13px; color:#C7D4E5;}
.hero-countdown{
  font-family:var(--f-mono); font-size:12.5px; padding:6px 11px; border-radius:8px; white-space:nowrap;
  background:rgba(255,255,255,0.1); color:var(--washi); border:1px solid rgba(255,255,255,0.18);
}
.hero-countdown.today{background:var(--shu); border-color:var(--shu);}
.hero-meta{margin-top:14px; padding-top:12px; border-top:1px dashed rgba(255,255,255,0.18); font-size:13px; color:#C7D4E5; display:flex; flex-wrap:wrap; gap:14px;}
.hero-meta b{color:var(--washi); font-weight:600;}
.hero-nextleg{margin-top:10px; font-family:var(--f-mono); font-size:11.5px; color:#9FB3CE;}
.hero-empty{padding:8px 2px 4px;}
.hero-empty p{margin:8px 0 0; color:#C7D4E5; font-size:14px; max-width:38ch;}
.hero.past{background-image:
    linear-gradient(to right, var(--kin-soft) 2px, transparent 2px), linear-gradient(to bottom, var(--kin-soft) 2px, transparent 2px),
    linear-gradient(to left, var(--kin-soft) 2px, transparent 2px), linear-gradient(to bottom, var(--kin-soft) 2px, transparent 2px),
    linear-gradient(to right, var(--kin-soft) 2px, transparent 2px), linear-gradient(to top, var(--kin-soft) 2px, transparent 2px),
    linear-gradient(to left, var(--kin-soft) 2px, transparent 2px), linear-gradient(to top, var(--kin-soft) 2px, transparent 2px),
    linear-gradient(165deg, #5b554a 0%, #3a352c 100%);
}

/* ===================== BADGE TRASPORTO ===================== */
.badge{
  font-family:var(--f-mono); font-size:10.5px; font-weight:700; letter-spacing:.05em; text-transform:uppercase;
  color:#fff; padding:4px 9px; border-radius:6px; display:inline-flex; align-items:center; gap:5px; flex:none;
}
.badge[data-tipo="aereo"]{background:var(--sora);}
.badge[data-tipo="shinkansen"]{background:var(--kon);}
.badge[data-tipo="treno"]{background:var(--matcha);}
.badge[data-tipo="bus"]{background:var(--odo);}
.badge[data-tipo="traghetto"]{background:var(--seiji);}
.badge[data-tipo="piedi"]{background:var(--tsuchi);}
.badge[data-tipo="altro"]{background:var(--mist);}

/* ===================== DOCUMENTI (chip biglietto) ===================== */
.doc-grid{display:grid; grid-template-columns:repeat(auto-fill,minmax(84px,1fr)); gap:10px; margin-top:10px;}
.doc-chip{
  background:var(--washi-card); border:1px solid var(--line); border-radius:12px; padding:0; overflow:hidden;
  text-align:left; position:relative; box-shadow:var(--shadow); aspect-ratio:1/1;
}
.doc-chip img{width:100%; height:100%; object-fit:cover; display:block;}
.doc-chip .pdf-mark{
  height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:4px;
  color:var(--kon); font-family:var(--f-mono); font-size:10px; font-weight:700; background:var(--washi-deep);
}
.doc-chip .doc-label{
  position:absolute; bottom:0; left:0; right:0; background:rgba(28,27,26,0.72); color:#fff; font-size:10px;
  padding:4px 6px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; font-family:var(--f-body);
}
.doc-chip .del-x{
  position:absolute; top:3px; right:3px; width:20px; height:20px; border-radius:50%; background:rgba(28,27,26,0.55);
  color:#fff; border:none; font-size:13px; line-height:1; display:flex; align-items:center; justify-content:center;
}
.doc-add{
  background:var(--washi); border:1.5px dashed var(--line-strong); border-radius:12px; aspect-ratio:1/1;
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap:4px; color:var(--mist);
  font-size:11px; font-family:var(--f-mono);
}
.doc-add svg{width:18px; height:18px;}

/* ===================== EMPTY STATES ===================== */
.empty{
  border:1.5px dashed var(--line-strong); border-radius:14px; padding:22px 18px; text-align:center; color:var(--mist);
  font-size:13.5px; background:rgba(255,255,255,0.3);
}
.empty b{display:block; color:var(--sumi); font-family:var(--f-display); font-size:15px; margin-bottom:4px;}

/* ===================== INFO BLOCK (note generali) ===================== */
.info-block{
  background:var(--washi-card); border:1px solid var(--line); border-radius:14px; padding:18px 20px;
  font-size:13.5px; line-height:1.7; white-space:pre-wrap; color:var(--sumi); box-shadow:var(--shadow);
}

/* ===================== TIMELINE / TAPPE ===================== */
.timeline{position:relative; margin-top:6px;}
.tappa{
  background:var(--washi-card); border-radius:16px; margin-bottom:14px; box-shadow:var(--shadow);
  border:1px solid var(--line); position:relative;
}
.tappa::before, .tappa::after{
  content:''; position:absolute; width:16px; height:16px; border-radius:50%; background:var(--washi); top:50%;
  transform:translateY(-50%); z-index:2;
}
.tappa::before{left:-9px;} .tappa::after{right:-9px;}
.tappa summary{list-style:none; cursor:pointer; padding:16px 18px; display:flex; gap:12px; align-items:center;}
.tappa summary::-webkit-details-marker{display:none;}
.tappa-num{
  font-family:var(--f-display); font-size:13px; color:var(--washi); background:var(--shu); border-radius:50%;
  width:32px; height:32px; display:flex; align-items:center; justify-content:center; flex:none; font-weight:700;
  border:1.5px solid #8C341E; box-shadow:inset 0 0 0 1.5px rgba(255,255,255,0.5);
}
.tappa-info{flex:1; min-width:0;}
.tappa-info h3{font-size:18px; color:var(--sumi);}
.tappa-info .range{font-family:var(--f-mono); font-size:12px; color:var(--mist); margin-top:2px;}
.tappa-chev{color:var(--mist); transition:transform .2s; flex:none;}
.tappa[open] .tappa-chev{transform:rotate(180deg);}
.tappa-body{padding:0 18px 18px; border-top:1px dashed var(--line);}
.tappa-block{margin-top:16px;}
.tappa-block .blk-head{display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;}
.tappa-block .blk-head h4{font-size:12px; letter-spacing:.07em; text-transform:uppercase; color:var(--mist); display:flex; align-items:center; gap:7px;}
.tappa-block .blk-head h4::before{content:''; width:12px; height:2px; background:var(--kin); flex:none; display:inline-block;}
.alloggio-card{background:var(--washi-deep); border-radius:11px; padding:12px 14px; font-size:13.5px;}
.alloggio-card .nome{font-weight:600; color:var(--sumi);}
.alloggio-card .riga{color:var(--mist); margin-top:3px; font-size:12.5px;}
.alloggio-card .riga b{color:var(--sumi); font-weight:600;}
.citta-info{background:var(--washi-deep); border-radius:11px; padding:13px 15px;}
.citta-info .tagline{font-style:italic; font-size:13.5px; color:var(--sumi); line-height:1.55; margin:0 0 9px;}
.citta-info ul{list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:6px;}
.citta-info li{font-size:12.5px; color:var(--sumi); line-height:1.45; display:flex; gap:8px; align-items:baseline;}
.citta-info li::before{content:''; width:6px; height:6px; background:var(--shu); transform:rotate(45deg); flex:none; display:inline-block;}
.hotel-maps-btn{
  display:inline-flex; align-items:center; gap:7px; margin-top:11px; font-weight:600; font-size:13px;
  color:var(--washi); text-decoration:none; padding:9px 14px; background:var(--kon); border-radius:9px;
}
.hotel-maps-btn:active{background:var(--kon-soft);}

.segmento{
  padding:10px 0; border-bottom:1px solid var(--line);
}
.segmento:last-child{border-bottom:none;}
.segmento-top{display:flex; align-items:center; justify-content:space-between; gap:8px;}
.segmento-top-right{display:flex; align-items:center; gap:6px; flex:none;}
.segmento-route{font-size:14px; font-weight:600; margin-top:7px; line-height:1.4; word-break:break-word;}
.segmento-route .arrow{color:var(--mist); font-weight:400;}
.segmento-meta{font-family:var(--f-mono); font-size:11px; color:var(--mist); margin-top:4px; line-height:1.5; word-break:break-word;}
.segmento-time{font-family:var(--f-mono); font-weight:700; font-size:14px; color:var(--kon); white-space:nowrap;}
.segmento-maps{
  display:inline-flex; align-items:center; gap:6px; margin-top:8px; font-family:var(--f-mono); font-size:11.5px;
  color:var(--kon); text-decoration:none; padding:6px 11px; background:var(--washi-card); border-radius:8px;
  border:1px solid var(--line-strong);
}
.segmento-maps:active{background:var(--washi-deep);}
.segmento-maps svg{flex:none;}

.row-actions{display:flex; gap:14px; margin-top:4px;}
.tappa-footer-actions{display:flex; gap:10px; margin-top:16px; flex-wrap:wrap;}

.giorno{
  background:var(--washi-deep); border-left:3px solid var(--kon); border-radius:0 12px 12px 0;
  margin-bottom:10px; overflow:hidden;
}
.giorno summary{list-style:none; cursor:pointer; padding:13px 15px;}
.giorno summary::-webkit-details-marker{display:none;}
.giorno-head{display:flex; justify-content:space-between; align-items:flex-start; gap:8px;}
.giorno-heading{min-width:0;}
.giorno-data{font-family:var(--f-mono); font-size:11px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--kon);}
.giorno-titolo{font-family:var(--f-display); font-size:15px; font-weight:700; color:var(--sumi); margin-top:2px;}
.giorno-actions{display:flex; gap:4px; align-items:center; flex:none;}
.giorno-chev{color:var(--mist); transition:transform .2s; display:flex; align-items:center; padding:0 2px;}
.giorno[open] .giorno-chev{transform:rotate(180deg);}
.giorno-body{padding:0 15px 13px;}
.giorno-note{font-size:13px; color:var(--sumi); white-space:pre-wrap; line-height:1.6;}
.giorno-segmenti{margin-top:10px; padding-top:8px; border-top:1px dashed var(--line-strong); background:var(--washi-card); border-radius:9px; padding:8px 10px;}
.giorno-segmenti .segmento{padding:7px 0;}
.tappa-note-block{background:var(--washi-deep); border-radius:11px; padding:12px 14px; font-size:13px; white-space:pre-wrap; line-height:1.6; color:var(--sumi);}

/* ===================== MODAL ===================== */
.overlay{
  position:fixed; inset:0; background:rgba(20,18,15,0.5); display:none; align-items:flex-end; justify-content:center;
  z-index:50; backdrop-filter:blur(2px);
}
.overlay.show{display:flex;}
.modal{
  background:var(--washi); width:100%; max-width:640px; border-radius:20px 20px 0 0; max-height:88vh;
  overflow-y:auto; padding:20px 20px calc(20px + env(safe-area-inset-bottom));
  animation:slideUp .22s ease-out;
}
@media (min-width:640px){
  .overlay{align-items:center;}
  .modal{border-radius:18px; max-height:85vh;}
}
@keyframes slideUp{from{transform:translateY(24px); opacity:0;} to{transform:translateY(0); opacity:1;}}
.modal h3{font-size:18px; color:var(--kon); margin-bottom:14px;}
.field{margin-bottom:13px;}
.field label{display:block; font-size:12px; font-weight:600; color:var(--mist); margin-bottom:5px; letter-spacing:.02em;}
.field input, .field select, .field textarea{
  width:100%; border:1.5px solid var(--line-strong); border-radius:10px; padding:11px 12px; background:var(--washi-card);
  color:var(--sumi);
}
.field input:focus, .field select:focus, .field textarea:focus{border-color:var(--kon);}
.field-row{display:flex; gap:10px;}
.field-row .field{flex:1; min-width:0;}
@media (max-width:480px){
  .field-row{flex-direction:column; gap:13px;}
  .field-row .field input[type="datetime-local"],
  .field-row .field input[type="date"]{width:100%;}
}
.modal-actions{display:flex; gap:10px; margin-top:18px;}
.modal-actions .btn{flex:1;}
.file-input-wrap{
  border:1.5px dashed var(--line-strong); border-radius:11px; padding:16px; text-align:center; color:var(--mist); font-size:13px;
}
.file-input-wrap input{margin-top:8px;}

/* ===================== LIGHTBOX ===================== */
