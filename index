  const raw = await storageGetRaw(STORAGE_KEY);
  if (raw){
    try{ state = JSON.parse(raw); }catch(e){ /* dati corrotti, mantieni il seed di default */ }
  } else {
    isFirstRun = true; // niente in storage: prima apertura, usiamo l'itinerario precaricato
  }
}

